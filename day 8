#include <iostream>
using namespace std;

 Problem -- 1
 Inheritance 
 Types -- 1.1 Single Inheritance

 class Vehicle {
 public:
     void start() {
         cout << "Vehicle Starts" << "\n";
     }
 };

 class Car : public Vehicle {
 public:
void drive() {
         cout << "Car is running" << "\n";
     }
};

 int main() {
     Car obj1;
     obj1.drive();
     obj1.start();
 }

// Types -- 1.2 MultiLevel Inheritance

class Vehicle {
public:
    void start() {
        cout << "Vehicle Starts" << "\n";
    }
};

class Car : public Vehicle {
public:
    void drive() {
        cout << "Car is running" << "\n";
    }
};

class speedoMeter : public Car {
public:
    void speed(){
        cout << "Car is running at 60km/h" <<"\n";
    }
};

int main() {
    speedoMeter obj1;
    obj1.speed();
    obj1.drive();
    obj1.start();
}
